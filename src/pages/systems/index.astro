---
import { existsSync } from 'node:fs';
import { join } from 'node:path';
import BaseLayout from '@layouts/BaseLayout.astro';
import { captureKindLabels, captureTargets } from '../../data/boot-screenshots.js';

const publicPath = (path) => join(process.cwd(), 'public', path.replace(/^\//, ''));
const captureKindOrder = Object.keys(captureKindLabels);
const allTargets = captureTargets().map((target) => ({
  ...target,
  hasImage: existsSync(publicPath(target.image)),
}));
const captureName = (target) => target.variantName
  ? `${target.systemName}: ${target.variantName}`
  : target.systemName;
const captureSections = captureKindOrder
  .map((kind) => ({
    kind,
    label: captureKindLabels[kind],
    targets: allTargets.filter((target) => target.kind === kind),
  }))
  .filter((section) => section.targets.length > 0);

const capturedCount = allTargets.filter((target) => target.hasImage).length;
const mediaPendingCount = allTargets.filter((target) => !target.hasImage && target.capture.mediaEnv).length;
const catalogRows = [...allTargets].sort((left, right) => (
  left.systemName.localeCompare(right.systemName)
  || (left.variantName ?? '').localeCompare(right.variantName ?? '')
  || left.kind.localeCompare(right.kind)
));
---

<BaseLayout title="System Matrix" description="Current Emu198x system support matrix.">
  <main class="container systems" data-pagefind-body>
    <header>
      <p class="eyebrow">Fleet status</p>
      <h1>System matrix</h1>
      <p>
        Emu198x separates support into capability surfaces. Primary systems have
        native windows; extended systems are headless but scriptable and
        MCP-driven. This page shows repeatable captures for every supported
        system as boot, BASIC, and software evidence becomes available.
      </p>
    </header>

    <section class="stat-grid" aria-label="Screenshot summary">
      <div class="stat"><strong>{capturedCount}</strong><span>captures published</span></div>
      <div class="stat"><strong>{allTargets.length}</strong><span>targets tracked</span></div>
      <div class="stat"><strong>{mediaPendingCount}</strong><span>waiting on local media</span></div>
    </section>

    <section class="panel">
      <div class="panel-heading">
        <div>
          <p class="eyebrow">Capture gallery</p>
          <h2>Current system captures</h2>
        </div>
        <a href="/accuracy/">Accuracy progress</a>
      </div>
      <div class="capture-sections">
        {captureSections.map((section) => (
          <section class="capture-section" aria-labelledby={`capture-${section.kind}`}>
            <div class="capture-section-heading">
              <h3 id={`capture-${section.kind}`}>{section.label}</h3>
              <span>
                {section.targets.filter((target) => target.hasImage).length}
                {' / '}
                {section.targets.length}
                {' published'}
              </span>
            </div>
            <div class="capture-grid">
              {section.targets.map((target) => (
                <article class="capture-card">
                  <a class="frame" href={target.href} aria-label={`${captureName(target)} system docs`}>
                    {target.hasImage ? (
                      <img src={target.image} alt={`${target.title} screenshot`} loading="lazy" decoding="async" />
                    ) : (
                      <span>
                        {target.capture.mediaEnv ? `${target.capture.mediaEnv}` : 'Capture pending'}
                      </span>
                    )}
                  </a>
                  <div class="capture-card-copy">
                    <div>
                      <p class="tier">{target.group}</p>
                      <h4><a href={target.href}>{captureName(target)}</a></h4>
                    </div>
                    <p>{target.caption}</p>
                    <p class={target.hasImage ? 'capture-state published' : 'capture-state pending'}>
                      {target.hasImage ? 'Published capture' : target.capture.mediaEnv ? 'Waiting on local media' : 'Capture pending'}
                    </p>
                  </div>
                </article>
              ))}
            </div>
          </section>
        ))}
      </div>
    </section>

    <section class="panel">
      <h2>Capture catalog</h2>
      <p>
        Screenshots are generated from the emulator source checkout with
        {' '}<code>npm run capture:screenshots</code>. Media-dependent targets
        are skipped until their environment variable is set locally.
      </p>
      <div class="table-wrap">
        <table>
          <thead><tr><th>System</th><th>Capture</th><th>Type</th><th>Media</th></tr></thead>
          <tbody>
            {catalogRows.map((target) => (
              <tr>
                <td><a href={target.href}>{target.variantName ? `${target.systemName}: ${target.variantName}` : target.systemName}</a></td>
                <td>
                  <span class="catalog-title">{target.title}</span>
                  <code>{target.capture.package}</code>
                </td>
                <td>{captureKindLabels[target.kind] ?? target.kind}</td>
                <td>{target.capture.mediaEnv ? <code>{target.capture.mediaEnv}</code> : 'Local firmware'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="panel">
      <h2>Next capture layers</h2>
      <p>
        The capture model now separates boot, BASIC, and software evidence.
        BASIC captures can use small Emu198x-authored programs, while software
        captures can be added from local media variables and captioned with the
        title, publisher, year, and capture context.
      </p>
    </section>
  </main>
</BaseLayout>

<style>
  .systems {
    padding-top: 4rem;
  }

  header {
    max-width: 880px;
  }

  h1 {
    margin: 0;
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.92;
  }

  header p:last-child {
    font-size: 1.25rem;
    line-height: 1.55;
  }

  .stat-grid {
    margin-top: 2rem;
  }

  .panel {
    margin-top: 2rem;
    border-radius: var(--radius);
    padding: clamp(1rem, 3vw, 1.5rem);
    background: var(--panel);
    box-shadow: inset 0 0 0 1px var(--line), var(--shadow-sm);
  }

  .panel-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .panel-heading h2,
  h2 {
    margin: 0;
  }

  .panel-heading a {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    font-weight: 650;
    white-space: nowrap;
  }

  .frame {
    display: grid;
    min-height: 164px;
    aspect-ratio: 4 / 3;
    place-items: center;
    overflow: hidden;
    background: #14161b;
    color: #d5dae3;
    text-decoration: none;
  }

  .frame img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    image-rendering: pixelated;
  }

  .frame span {
    max-width: 18ch;
    padding: 0.75rem;
    color: #d5dae3;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1.35;
    overflow-wrap: anywhere;
    text-align: center;
  }

  .capture-sections {
    display: grid;
    gap: 1.5rem;
  }

  .capture-section {
    min-width: 0;
  }

  .capture-section-heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.85rem;
  }

  .capture-section-heading h3 {
    margin: 0;
    color: var(--ink);
    font-size: 1.25rem;
  }

  .capture-section-heading span {
    color: var(--ink-soft);
    font-size: 0.86rem;
    font-weight: 650;
    white-space: nowrap;
  }

  .capture-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
    gap: 1rem;
  }

  .capture-card {
    overflow: hidden;
    border-radius: var(--radius);
    background: var(--paper-strong);
    box-shadow: inset 0 0 0 1px var(--line), var(--shadow-sm);
  }

  .capture-card-copy {
    display: grid;
    gap: 0.65rem;
    padding: 1rem;
  }

  .tier {
    margin: 0 0 0.2rem;
    color: var(--accent-strong);
    font-size: 0.72rem;
    font-weight: 750;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h4 {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.25;
  }

  .capture-card-copy p {
    margin: 0;
    line-height: 1.45;
  }

  .capture-state {
    display: inline-flex;
    min-height: 30px;
    align-items: center;
    width: fit-content;
    border-radius: 999px;
    padding: 0.25rem 0.65rem;
    color: var(--ink-muted);
    font-size: 0.78rem;
    font-weight: 650;
    line-height: 1.25;
  }

  .capture-state.published {
    background: rgba(22, 101, 52, 0.1);
    box-shadow: inset 0 0 0 1px rgba(22, 101, 52, 0.2);
  }

  .capture-state.pending {
    background: rgba(198, 63, 49, 0.08);
    box-shadow: inset 0 0 0 1px rgba(198, 63, 49, 0.18);
  }

  .table-wrap {
    overflow-x: auto;
  }

  .catalog-title {
    display: block;
    margin-bottom: 0.25rem;
    font-weight: 650;
  }

  td:first-child,
  th:first-child {
    min-width: 220px;
  }

  td:nth-child(2),
  td:nth-child(4) {
    min-width: 220px;
  }

  @media (max-width: 760px) {
    .panel-heading {
      align-items: start;
      flex-direction: column;
    }

    .capture-section-heading {
      align-items: start;
      flex-direction: column;
      gap: 0.35rem;
    }

    .capture-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
