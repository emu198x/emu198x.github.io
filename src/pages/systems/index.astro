---
import { existsSync } from 'node:fs';
import { join } from 'node:path';
import BaseLayout from '@layouts/BaseLayout.astro';
import { captureKindLabels, captureTargets, bootScreenshots } from '../../data/boot-screenshots.js';

const publicPath = (path) => join(process.cwd(), 'public', path.replace(/^\//, ''));
const captureKindOrder = Object.keys(captureKindLabels);
const allTargets = captureTargets().map((target) => ({
  ...target,
  hasImage: existsSync(publicPath(target.image)),
}));
const targetsById = new Map(allTargets.map((target) => [target.id, target]));
const withAvailability = bootScreenshots.map((system) => {
  const primaryTarget = targetsById.get(system.id);
  const systemTargets = allTargets.filter((target) => target.systemId === system.id);
  return {
    ...system,
    ...primaryTarget,
    variants: systemTargets.filter((target) => target.variantId),
    captures: systemTargets,
    captureCounts: captureKindOrder
      .map((kind) => ({
        kind,
        label: captureKindLabels[kind],
        total: systemTargets.filter((target) => target.kind === kind).length,
        captured: systemTargets.filter((target) => target.kind === kind && target.hasImage).length,
      }))
      .filter((item) => item.total > 0),
    pendingMediaCount: systemTargets.filter((target) => !target.hasImage && target.capture.mediaEnv).length,
  };
});

const capturedCount = allTargets.filter((target) => target.hasImage).length;
const mediaPendingCount = allTargets.filter((target) => !target.hasImage && target.capture.mediaEnv).length;
const catalogRows = [...allTargets].sort((left, right) => (
  left.systemName.localeCompare(right.systemName)
  || (left.variantName ?? '').localeCompare(right.variantName ?? '')
  || left.kind.localeCompare(right.kind)
));
---

<BaseLayout title="System Matrix" description="Current Emu198x system support matrix.">
  <main class="container systems">
    <header>
      <p class="eyebrow">Fleet status</p>
      <h1>System matrix</h1>
      <p>
        Emu198x separates support into capability surfaces. Primary systems have
        native windows; extended systems are headless but scriptable and
        MCP-driven. This page shows repeatable captures for every supported
        system as boot, BASIC, and software evidence becomes available.
      </p>
    </header>

    <section class="stat-grid" aria-label="Screenshot summary">
      <div class="stat"><strong>{capturedCount}</strong><span>captures published</span></div>
      <div class="stat"><strong>{allTargets.length}</strong><span>targets tracked</span></div>
      <div class="stat"><strong>{mediaPendingCount}</strong><span>waiting on local media</span></div>
    </section>

    <section class="panel">
      <div class="panel-heading">
        <div>
          <p class="eyebrow">Capture gallery</p>
          <h2>Current system captures</h2>
        </div>
        <a href="/accuracy/">Accuracy progress</a>
      </div>
      <div class="boot-grid">
        {withAvailability.map((system) => (
          <article class="boot-card">
            <a class="frame" href={system.href} aria-label={`${system.name} system docs`}>
              {system.hasImage ? (
                <img src={system.image} alt={`${system.name} boot screenshot`} loading="lazy" decoding="async" />
              ) : (
                <span>
                  {system.capture.mediaEnv ? `${system.capture.mediaEnv}` : 'Capture pending'}
                </span>
              )}
            </a>
            <div class="boot-card-copy">
              <div>
                <p class="tier">{system.group}</p>
                <h3><a href={system.href}>{system.name}</a></h3>
              </div>
              <p>{system.caption}</p>
              <div class="capture-counts" aria-label={`${system.name} capture counts`}>
                {system.captureCounts.map((item) => (
                  <span>
                    <strong>{item.captured}</strong>
                    {' '}
                    {item.captured === item.total ? item.label : `${item.label} / ${item.total}`}
                  </span>
                ))}
              </div>
              {(system.variants.length > 0 || system.pendingMediaCount > 0) && (
                <p class="coverage-note">
                  {system.variants.length > 0 && `${system.variants.length} variants tracked`}
                  {system.variants.length > 0 && system.pendingMediaCount > 0 && ' · '}
                  {system.pendingMediaCount > 0 && `${system.pendingMediaCount} media-gated captures pending`}
                </p>
              )}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="panel">
      <h2>Capture catalog</h2>
      <p>
        Screenshots are generated from the emulator source checkout with
        {' '}<code>npm run capture:screenshots</code>. Media-dependent targets
        are skipped until their environment variable is set locally.
      </p>
      <div class="table-wrap">
        <table>
          <thead><tr><th>System</th><th>Capture</th><th>Type</th><th>Media</th></tr></thead>
          <tbody>
            {catalogRows.map((target) => (
              <tr>
                <td><a href={target.href}>{target.variantName ? `${target.systemName}: ${target.variantName}` : target.systemName}</a></td>
                <td>
                  <span class="catalog-title">{target.title}</span>
                  <code>{target.capture.package}</code>
                </td>
                <td>{captureKindLabels[target.kind] ?? target.kind}</td>
                <td>{target.capture.mediaEnv ? <code>{target.capture.mediaEnv}</code> : 'Local firmware'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="panel">
      <h2>Next capture layers</h2>
      <p>
        The capture model now separates boot, BASIC, and software evidence.
        BASIC captures can use small Emu198x-authored programs, while software
        captures can be added from local media variables and captioned with the
        title, publisher, year, and capture context.
      </p>
    </section>
  </main>
</BaseLayout>

<style>
  .systems {
    padding-top: 4rem;
  }

  header {
    max-width: 880px;
  }

  h1 {
    margin: 0;
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.92;
  }

  header p:last-child {
    font-size: 1.25rem;
    line-height: 1.55;
  }

  .stat-grid {
    margin-top: 2rem;
  }

  .panel {
    margin-top: 2rem;
    border-radius: var(--radius);
    padding: clamp(1rem, 3vw, 1.5rem);
    background: var(--panel);
    box-shadow: inset 0 0 0 1px var(--line), var(--shadow-sm);
  }

  .panel-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .panel-heading h2,
  h2 {
    margin: 0;
  }

  .panel-heading a {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    font-weight: 650;
    white-space: nowrap;
  }

  .boot-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1rem;
  }

  .boot-card {
    overflow: hidden;
    border-radius: var(--radius);
    background: var(--paper-strong);
    box-shadow: inset 0 0 0 1px var(--line), var(--shadow-sm);
  }

  .frame {
    display: grid;
    min-height: 164px;
    aspect-ratio: 4 / 3;
    place-items: center;
    overflow: hidden;
    background: #14161b;
    color: #d5dae3;
    text-decoration: none;
  }

  .frame img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    image-rendering: pixelated;
  }

  .frame span {
    max-width: 18ch;
    padding: 0.75rem;
    color: #d5dae3;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1.35;
    overflow-wrap: anywhere;
    text-align: center;
  }

  .boot-card-copy {
    display: grid;
    gap: 0.65rem;
    padding: 1rem;
  }

  .tier {
    margin: 0 0 0.2rem;
    color: var(--accent-strong);
    font-size: 0.72rem;
    font-weight: 750;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h3 {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.25;
  }

  .boot-card-copy p {
    margin: 0;
    line-height: 1.45;
  }

  .capture-counts {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    min-width: 0;
  }

  .capture-counts span {
    display: inline-flex;
    min-height: 30px;
    align-items: center;
    gap: 0.35rem;
    border-radius: 999px;
    padding: 0.25rem 0.65rem;
    background: rgba(22, 101, 52, 0.1);
    color: var(--ink-muted);
    font-size: 0.78rem;
    font-weight: 650;
    line-height: 1.25;
    box-shadow: inset 0 0 0 1px rgba(22, 101, 52, 0.2);
  }

  .capture-counts strong {
    color: var(--ink);
    font-variant-numeric: tabular-nums;
  }

  .coverage-note {
    color: var(--ink-muted);
    font-size: 0.86rem;
  }

  .table-wrap {
    overflow-x: auto;
  }

  .catalog-title {
    display: block;
    margin-bottom: 0.25rem;
    font-weight: 650;
  }

  td:first-child,
  th:first-child {
    min-width: 220px;
  }

  td:nth-child(2),
  td:nth-child(4) {
    min-width: 220px;
  }

  @media (max-width: 760px) {
    .panel-heading {
      align-items: start;
      flex-direction: column;
    }

    .boot-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
