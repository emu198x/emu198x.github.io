---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Emu198x" description="A public evidence site for the Emu198x multi-system emulator suite.">
  <main>
    <section class="hero">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">Multi-system emulator suite</p>
          <h1>Emu198x</h1>
          <p class="lede">
            Cycle-accurate vintage computers and consoles with one deterministic
            automation surface, public accuracy evidence, and hardware-aware
            documentation.
          </p>
          <div class="actions">
            <a class="button primary" href="/accuracy/">Accuracy progress</a>
            <a class="button secondary" href="/systems/">System matrix</a>
          </div>
        </div>
        <div class="evidence-panel" aria-label="Current Emu198x support summary">
          <div class="panel-header">
            <span class="pill">Current fleet</span>
            <span>July 2026</span>
          </div>
          <div class="stat-grid">
            <div class="stat"><strong>6</strong><span>primary systems</span></div>
            <div class="stat"><strong>22</strong><span>extended systems</span></div>
            <div class="stat"><strong>28</strong><span>MCP-driven runtimes</span></div>
            <div class="stat"><strong>All</strong><span>supported systems tracked</span></div>
          </div>
        </div>
      </div>
    </section>

    <section class="container section-grid" aria-label="Project priorities">
      <article>
        <p class="eyebrow">Accuracy</p>
        <h2>Claims backed by dashboards.</h2>
        <p>
          The site exists to make emulator claims inspectable across every
          supported system: test canons, pass rates, known failures,
          compatibility sweeps, and measurement provenance.
        </p>
      </article>
      <article>
        <p class="eyebrow">Tooling</p>
        <h2>One control surface across the fleet.</h2>
        <p>
          Capture, scripting, snapshots, and MCP let tools and agents drive
          different machines consistently without flattening their internals.
        </p>
      </article>
      <article>
        <p class="eyebrow">Scope</p>
        <h2>Machine-specific timing stays machine-specific.</h2>
        <p>
          Shared infrastructure lives above the cores. Video, audio, DMA, media,
          and bus arbitration stay in the family that owns the hardware.
        </p>
      </article>
    </section>
  </main>
</BaseLayout>

<style>
  .hero {
    border-bottom: 1px solid var(--line);
    background:
      linear-gradient(135deg, rgba(11, 110, 105, 0.11), transparent 42%),
      var(--paper);
  }

  .hero-grid {
    display: grid;
    min-height: calc(100svh - 64px);
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
    gap: 4rem;
    align-items: center;
    padding-block: 4rem;
  }

  h1 {
    margin: 0;
    color: var(--ink);
    font-size: clamp(4rem, 12vw, 9rem);
    line-height: 0.86;
  }

  .lede {
    max-width: 680px;
    margin: 1.4rem 0 0;
    font-size: clamp(1.2rem, 2.1vw, 1.55rem);
    line-height: 1.48;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .button {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    border-radius: 7px;
    padding: 0 1rem;
    font-weight: 700;
    text-decoration: none;
  }

  .primary {
    background: var(--accent);
    color: white;
  }

  .secondary {
    background: var(--panel);
    color: var(--ink);
    box-shadow: inset 0 0 0 1px var(--line-strong);
  }

  .evidence-panel {
    border-radius: var(--radius);
    padding: 1rem;
    background: rgba(255, 255, 255, 0.72);
    box-shadow: inset 0 0 0 1px var(--line), var(--shadow-md);
  }

  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.9rem;
    color: var(--ink-soft);
    font-size: 0.9rem;
  }

  .section-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
    padding-block: 4rem;
  }

  .section-grid article {
    min-width: 0;
  }

  .section-grid h2 {
    margin: 0;
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    line-height: 1.06;
  }

  .section-grid p:last-child {
    margin-bottom: 0;
  }

  @media (hover: hover) and (pointer: fine) {
    .primary:hover {
      background: var(--accent-strong);
      color: white;
    }

    .secondary:hover {
      background: var(--paper-strong);
      color: var(--accent-strong);
    }
  }

  @media (max-width: 900px) {
    .hero-grid,
    .section-grid {
      grid-template-columns: 1fr;
    }

    .hero-grid {
      min-height: auto;
      gap: 2rem;
    }
  }
</style>
